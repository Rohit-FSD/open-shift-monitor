@Service
@RequiredArgsConstructor
@Slf4j
public class TokenService {

    private final RestClientService restClientService;

    private final Map<String, Token> tokenCache = new ConcurrentHashMap<>();

    @Value("#{${apps.name.system.account.password}}")
    private Map<String, String> systemAccounts;

    public Token getToken(String env, String host, String systemAccount) {

        Token cached = tokenCache.get(env);

        if (cached == null || isExpired(cached)) {
            log.info("Generating new token for {}", env);
            Token newToken = generateToken(host, systemAccount);
            tokenCache.put(env, newToken);
            return newToken;
        }

        return cached;
    }

    private boolean isExpired(Token token) {
        return LocalDateTime.now()
                .isAfter(token.getExpiryTime().minusMinutes(2));
    }

    private Token generateToken(String host, String systemAccount) {

        String encodedCreds = systemAccounts.get(systemAccount);

        HttpHeaders headers = new HttpHeaders();
        headers.setBasicAuth(encodedCreds);

        String oauthHost = host
                .replace("api.", "oauth-openshift.apps.")
                .replace(":6443", "");

        ResponseEntity<String> response =
                restClientService.makeGetCall(
                        oauthHost + "/oauth/authorize?response_type=token&client_id=openshift-challenging-client",
                        headers
                );

        URI location = response.getHeaders().getLocation();

        return extractToken(location);
    }

    private Token extractToken(URI uri) {

        String fragment = uri.getFragment();

        Map<String, String> map = Arrays.stream(fragment.split("&"))
                .map(s -> s.split("="))
                .collect(Collectors.toMap(a -> a[0], a -> a[1]));

        Token token = new Token();
        token.setAccessToken(map.get("access_token"));

        long expiresIn = Long.parseLong(map.get("expires_in"));

        token.setExpiryTime(LocalDateTime.now().plusSeconds(expiresIn));

        return token;
    }
}
