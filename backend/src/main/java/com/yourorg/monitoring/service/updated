private boolean isBackgroundLog(String block) {
    String b = block.toLowerCase();
    // generic scheduler signals
    return b.contains("scheduled") ||
           b.contains("scheduling") ||
           b.contains("cron") ||
           b.contains("quartz") ||
           b.contains("timer") ||
           b.contains("rotation") ||
           b.contains("housekeeping");
}
